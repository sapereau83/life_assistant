<% d = entry.delta %>
<tbody id="<%= dom_id(entry) %>" data-controller="inline-edit" data-action="keydown->inline-edit#keydown" class="border-t border-stroke">
  <tr data-inline-edit-target="display" class="text-boxdark">
    <td class="px-6 py-3 font-medium"><%= l(entry.recorded_on, format: :long) %></td>
    <td class="px-6 py-3"><%= number_with_precision(entry.weight_kg, precision: 1) %> kg</td>
    <td class="px-6 py-3">
      <% if d.nil? %>
        <span class="text-body">—</span>
      <% else %>
        <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium <%= d <= 0 ? 'bg-success/10 text-success' : 'bg-danger/10 text-danger' %>">
          <%= d > 0 ? "▲" : "▼" %> <%= number_with_precision(d.abs, precision: 1) %>
        </span>
      <% end %>
    </td>
    <td class="px-6 py-3 text-body"><%= entry.note.presence || "—" %></td>
    <td class="px-6 py-3">
      <div class="flex items-center justify-end gap-2">
        <button type="button" data-action="inline-edit#edit" class="text-body/60 transition hover:text-primary" aria-label="Modifier">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </button>
        <%= button_to weight_entry_path(entry), method: :delete, class: "text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Supprimer cette pesée ?" } }, aria: { label: "Supprimer" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
        <% end %>
      </div>
    </td>
  </tr>
  <tr data-inline-edit-target="form" hidden>
    <td colspan="5" class="bg-gray-2 px-6 py-3">
      <%= form_with model: entry, url: weight_entry_path(entry), method: :patch do |f| %>
        <div class="flex flex-wrap items-end gap-3">
          <div>
            <label class="mb-1 block text-xs font-medium text-body"><%= l(entry.recorded_on, format: :long) %></label>
            <%= f.hidden_field :recorded_on %>
            <%= f.number_field :weight_kg, step: 0.1, min: 0,
                  class: "w-28 rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
          </div>
          <div class="flex-1 min-w-[160px]">
            <label class="mb-1 block text-xs font-medium text-body">Note</label>
            <%= f.text_field :note, autocomplete: "off",
                  class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
          </div>
          <%= f.submit "Enregistrer", class: "cursor-pointer rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition hover:bg-primary-dark" %>
          <button type="button" data-action="inline-edit#cancel" class="rounded-lg border border-stroke px-4 py-2 text-sm text-body transition hover:bg-gray-2">Annuler</button>
        </div>
      <% end %>
    </td>
  </tr>
</tbody>
