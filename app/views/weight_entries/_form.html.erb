<%= form_with model: entry, url: weight_entries_path, method: :post, id: "new_weight_form" do |f| %>
  <% if entry.errors.any? %>
    <p class="mb-2 text-xs text-danger"><%= entry.errors.full_messages.to_sentence %></p>
  <% end %>
  <div class="flex flex-col gap-3 rounded-lg border border-dashed border-primary/40 bg-primary/5 p-3 sm:flex-row sm:items-end">
    <div class="flex-1">
      <label class="mb-1 block text-xs font-medium text-body">Date</label>
      <%= f.date_field :recorded_on,
            class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
    </div>
    <div class="flex-1">
      <label class="mb-1 block text-xs font-medium text-body">Poids (kg)</label>
      <%= f.number_field :weight_kg, step: 0.1, min: 0, placeholder: "ex. 87.5",
            class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
    </div>
    <div class="flex-[2]">
      <label class="mb-1 block text-xs font-medium text-body">Note (optionnel)</label>
      <%= f.text_field :note, autocomplete: "off", placeholder: "ex. après le sport",
            class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
    </div>
    <%= f.submit "Enregistrer",
          class: "cursor-pointer rounded-lg bg-primary px-5 py-2 text-sm font-medium text-white transition hover:bg-primary-dark" %>
  </div>
<% end %>
