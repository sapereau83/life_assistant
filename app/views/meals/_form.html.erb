<%= form_with model: meal, url: meals_path, method: :post, id: "new_meal_form" do |f| %>
  <% if meal.errors.any? %>
    <p class="mb-2 text-xs text-danger"><%= meal.errors.full_messages.to_sentence %></p>
  <% end %>
  <div class="rounded-lg border border-dashed border-primary/40 bg-primary/5 p-3">
    <div class="mb-3 w-full sm:w-56">
      <label class="mb-1 block text-xs font-medium text-body">Date</label>
      <%= f.date_field :recorded_on,
            class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
    </div>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <% { breakfast: "Petit-déj", lunch: "Déjeuner", dinner: "Dîner", snacks: "Snacks" }.each do |field, label| %>
        <div>
          <label class="mb-1 block text-xs font-medium text-body"><%= label %></label>
          <%= f.text_area field, rows: 3, placeholder: "un item par ligne…",
                class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
        </div>
      <% end %>
    </div>
    <div class="mt-3 text-right">
      <%= f.submit "Enregistrer la journée",
            class: "cursor-pointer rounded-lg bg-primary px-5 py-2 text-sm font-medium text-white transition hover:bg-primary-dark" %>
    </div>
  </div>
<% end %>
