<tbody id="<%= dom_id(meal) %>" data-controller="inline-edit" data-action="keydown->inline-edit#keydown" class="border-t border-stroke">
  <tr data-inline-edit-target="display" class="align-top text-boxdark">
    <td class="whitespace-nowrap px-4 py-3 font-medium"><%= l(meal.recorded_on, format: :long) %></td>
    <% Meal::MEALS.each do |m| %>
      <td class="px-4 py-3">
        <% if meal[m].present? %>
          <span class="whitespace-pre-line text-body"><%= meal[m] %></span>
        <% else %>
          <span class="text-body/40">—</span>
        <% end %>
      </td>
    <% end %>
    <td class="px-4 py-3">
      <div class="flex items-center justify-end gap-2">
        <button type="button" data-action="inline-edit#edit" class="text-body/60 transition hover:text-primary" aria-label="Modifier">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </button>
        <%= button_to meal_path(meal), method: :delete, class: "text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Supprimer cette journée ?" } }, aria: { label: "Supprimer" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
        <% end %>
      </div>
    </td>
  </tr>
  <tr data-inline-edit-target="form" hidden>
    <td colspan="6" class="bg-gray-2 px-4 py-3">
      <%= form_with model: meal, url: meal_path(meal), method: :patch do |f| %>
        <%= f.hidden_field :recorded_on %>
        <p class="mb-2 text-xs font-medium text-body"><%= l(meal.recorded_on, format: :long) %></p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
          <% { breakfast: "Petit-déj", lunch: "Déjeuner", dinner: "Dîner", snacks: "Snacks" }.each do |field, label| %>
            <div>
              <label class="mb-1 block text-xs font-medium text-body"><%= label %></label>
              <%= f.text_area field, rows: 3,
                    class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
            </div>
          <% end %>
        </div>
        <div class="mt-3 flex items-center gap-2">
          <%= f.submit "Enregistrer", class: "cursor-pointer rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition hover:bg-primary-dark" %>
          <button type="button" data-action="inline-edit#cancel" class="rounded-lg border border-stroke px-4 py-2 text-sm text-body transition hover:bg-white">Annuler</button>
        </div>
      <% end %>
    </td>
  </tr>
</tbody>
