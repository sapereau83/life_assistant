<% content_for :title, "Aujourd'hui · Life Assistant" %>
<% content_for :page_title, "Aujourd'hui" %>
<% content_for :page_subtitle, "Ta journée en un coup d'œil : tâches, poids et repas. À minuit, les tâches non faites basculent dans « À valider »." %>

<div class="space-y-6 pb-24 lg:pb-6">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div id="today_card">
      <%= render "today_card", today_tasks: @today_tasks, task: @new_task %>
    </div>

    <div id="bucket_card">
      <%= render "bucket_card", bucket: @bucket %>
    </div>
  </div>

  <div id="today_weight_card">
    <%= render "tasks/weight_card" %>
  </div>

  <div id="today_meal_card">
    <%= render "tasks/meal_card" %>
  </div>

  <div id="today_workout_card">
    <%= render "tasks/workout_card" %>
  </div>
</div>
