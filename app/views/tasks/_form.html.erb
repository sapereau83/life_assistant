<%= form_with model: task, url: tasks_path, method: :post, id: "new_task_form" do |f| %>
  <% if task.errors.any? %>
    <p class="mb-2 text-xs text-danger"><%= task.errors.full_messages.to_sentence %></p>
  <% end %>
  <div class="flex items-center gap-2">
    <%= f.text_field :title,
          placeholder: "Ajouter une tâche pour aujourd'hui…",
          autocomplete: "off",
          class: "w-full rounded-lg border border-stroke bg-gray-2 px-4 py-2.5 text-sm text-boxdark outline-none transition focus:border-primary" %>
    <%= f.submit "Ajouter",
          class: "flex-shrink-0 cursor-pointer rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-white transition hover:bg-primary-dark" %>
  </div>
<% end %>
