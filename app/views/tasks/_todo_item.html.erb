<li id="<%= dom_id(task, :list) %>" class="flex items-center gap-3 px-6 py-3">
  <% if task.done? %>
    <%= button_to reopen_task_path(task), method: :patch, class: "flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-md border border-success bg-success text-white", aria: { label: "Rouvrir" } do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    <% end %>
  <% else %>
    <%= button_to complete_task_path(task), method: :patch, class: "h-5 w-5 flex-shrink-0 rounded-md border border-stroke transition hover:border-primary", aria: { label: "Marquer comme fait" } do %>
      <span class="sr-only">Marquer comme fait</span>
    <% end %>
  <% end %>

  <span class="flex-1 text-sm <%= task.done? ? 'text-body line-through' : 'text-boxdark' %>">
    <%= task.title %>
  </span>

  <% if task.to_validate? %>
    <span class="flex-shrink-0 rounded-full bg-warning/10 px-2 py-0.5 text-xs font-medium text-warning">à valider · <%= l(task.day, format: :short) %></span>
  <% elsif task.todo? && task.day != Date.current %>
    <span class="flex-shrink-0 rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary"><%= l(task.day, format: :short) %></span>
  <% end %>

  <%= button_to toggle_recurring_task_path(task), method: :patch,
        class: "flex-shrink-0 transition #{task.recurring? ? 'text-primary' : 'text-body/40 hover:text-primary'}",
        title: task.recurring? ? "Tâche quotidienne — ne plus répéter" : "Répéter chaque jour",
        aria: { label: "Basculer récurrence quotidienne" } do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
  <% end %>

  <%= button_to task_path(task), method: :delete, class: "flex-shrink-0 text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Supprimer cette tâche ?" } }, aria: { label: "Supprimer" } do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
  <% end %>
</li>
