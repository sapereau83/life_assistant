<li id="<%= dom_id(task, :bucket) %>" class="flex items-center gap-3 px-6 py-3">
  <span class="flex h-2 w-2 flex-shrink-0 rounded-full bg-warning"></span>

  <div class="flex-1">
    <p class="text-sm text-boxdark"><%= task.title %></p>
    <p class="text-xs text-body">Reporté du <%= l(task.day, format: :short) %></p>
  </div>

  <%= button_to move_to_today_task_path(task), method: :patch, class: "flex-shrink-0 rounded-lg border border-primary px-3 py-1.5 text-xs font-medium text-primary transition hover:bg-primary hover:text-white" do %>
    → Aujourd'hui
  <% end %>

  <%= button_to task_path(task), method: :delete, class: "text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Supprimer définitivement ?" } }, aria: { label: "Supprimer" } do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
  <% end %>
</li>
