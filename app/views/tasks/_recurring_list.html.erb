<div class="rounded-lg border border-stroke bg-white shadow-default">
  <div class="flex items-center justify-between border-b border-stroke px-6 py-4">
    <div class="flex items-center gap-2">
      <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      <h2 class="text-lg font-semibold text-boxdark">Tâches quotidiennes</h2>
      <span class="rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary"><%= recurring.size %></span>
    </div>
  </div>

  <div class="border-b border-stroke px-6 py-4">
    <%= form_with url: recurring_tasks_path, method: :post, id: "new_recurring_form" do |f| %>
      <div class="flex items-center gap-2">
        <%= f.text_field "recurring_task[title]",
              placeholder: "Ajouter une tâche quotidienne (ex. Marche 10 000 pas)…",
              autocomplete: "off",
              class: "w-full rounded-lg border border-stroke bg-gray-2 px-4 py-2.5 text-sm text-boxdark outline-none transition focus:border-primary" %>
        <%= f.submit "Ajouter", class: "flex-shrink-0 cursor-pointer rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-white transition hover:bg-primary-dark" %>
      </div>
    <% end %>
  </div>

  <ul class="divide-y divide-stroke">
    <% if recurring.empty? %>
      <li class="px-6 py-8 text-center text-sm text-body">
        Aucune tâche quotidienne. Ajoute-en une, ou clique l'icône <span class="inline-block align-middle">🔁</span> sur une tâche pour la répéter chaque jour.
      </li>
    <% else %>
      <% recurring.each do |rt| %>
        <li class="flex items-center gap-3 px-6 py-3">
          <span class="flex h-2 w-2 flex-shrink-0 rounded-full bg-primary"></span>
          <span class="flex-1 text-sm text-boxdark"><%= rt.title %></span>
          <span class="text-xs text-body">chaque jour</span>
          <%= button_to recurring_task_path(rt), method: :delete, class: "text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Arrêter de répéter « #{rt.title} » ?" } }, aria: { label: "Supprimer" } do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
          <% end %>
        </li>
      <% end %>
    <% end %>
  </ul>
</div>
