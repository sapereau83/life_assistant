<tbody id="<%= dom_id(workout) %>" data-controller="inline-edit" data-action="keydown->inline-edit#keydown" class="border-t border-stroke">
  <tr data-inline-edit-target="display" class="align-top text-boxdark">
    <td class="whitespace-nowrap px-6 py-3 font-medium"><%= l(workout.recorded_on, format: :long) %></td>
    <td class="px-6 py-3">
      <% if workout.active? %>
        <span class="whitespace-pre-line text-body"><%= workout.description %></span>
      <% else %>
        <span class="text-body/40"><%= workout.description.presence || "repos" %></span>
      <% end %>
    </td>
    <td class="whitespace-nowrap px-6 py-3 text-body">
      <%= workout.duration_minutes.present? ? "#{workout.duration_minutes} min" : "—" %>
    </td>
    <td class="px-6 py-3">
      <% if workout.steps.present? %>
        <span class="font-medium text-boxdark"><%= number_with_delimiter(workout.steps) %></span>
      <% else %>
        <span class="text-body/40">—</span>
      <% end %>
    </td>
    <td class="px-6 py-3">
      <div class="flex items-center justify-end gap-2">
        <button type="button" data-action="inline-edit#edit" class="text-body/60 transition hover:text-primary" aria-label="Modifier">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </button>
        <%= button_to workout_path(workout), method: :delete, class: "text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Supprimer cette séance ?" } }, aria: { label: "Supprimer" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
        <% end %>
      </div>
    </td>
  </tr>
  <tr data-inline-edit-target="form" hidden>
    <td colspan="5" class="bg-gray-2 px-6 py-3">
      <%= form_with model: workout, url: workout_path(workout), method: :patch do |f| %>
        <%= f.hidden_field :recorded_on %>
        <div class="flex flex-wrap items-end gap-3">
          <div class="flex-1 min-w-[180px]">
            <label class="mb-1 block text-xs font-medium text-body"><%= l(workout.recorded_on, format: :long) %></label>
            <%= f.text_field :description, autocomplete: "off",
                  class: "w-full rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-body">Durée (min)</label>
            <%= f.number_field :duration_minutes, min: 0,
                  class: "w-28 rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium text-body">Pas</label>
            <%= f.number_field :steps, min: 0,
                  class: "w-32 rounded-lg border border-stroke bg-white px-3 py-2 text-sm text-boxdark outline-none focus:border-primary" %>
          </div>
          <%= f.submit "Enregistrer", class: "cursor-pointer rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition hover:bg-primary-dark" %>
          <button type="button" data-action="inline-edit#cancel" class="rounded-lg border border-stroke px-4 py-2 text-sm text-body transition hover:bg-white">Annuler</button>
        </div>
      <% end %>
    </td>
  </tr>
</tbody>
