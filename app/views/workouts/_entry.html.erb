<tr id="<%= dom_id(workout) %>" class="align-top text-boxdark">
  <td class="whitespace-nowrap px-6 py-3 font-medium"><%= l(workout.recorded_on, format: :long) %></td>
  <td class="px-6 py-3">
    <% if workout.active? %>
      <span class="whitespace-pre-line text-body"><%= workout.description %></span>
    <% else %>
      <span class="text-body/40"><%= workout.description.presence || "repos" %></span>
    <% end %>
  </td>
  <td class="whitespace-nowrap px-6 py-3 text-body">
    <%= workout.duration_minutes.present? ? "#{workout.duration_minutes} min" : "—" %>
  </td>
  <td class="px-6 py-3">
    <% if workout.steps.present? %>
      <span class="font-medium text-boxdark"><%= number_with_delimiter(workout.steps) %></span>
    <% else %>
      <span class="text-body/40">—</span>
    <% end %>
  </td>
  <td class="px-6 py-3 text-right">
    <%= button_to workout_path(workout), method: :delete, class: "text-body/60 transition hover:text-danger", form: { data: { turbo_confirm: "Supprimer cette séance ?" } }, aria: { label: "Supprimer" } do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2m-7 0v12a1 1 0 001 1h6a1 1 0 001-1V7"/></svg>
    <% end %>
  </td>
</tr>
