<%# Progress toward the user's goals, with a nudge when behind. %>
<div class="mb-6 rounded-lg border border-stroke bg-white p-5 shadow-default sm:p-6">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h2 class="text-lg font-semibold text-boxdark">Objectifs</h2>
      <p class="text-sm text-body">Ta progression vers tes cibles.</p>
    </div>
    <%= link_to "Modifier", edit_goal_path, class: "text-sm font-medium text-primary hover:underline" %>
  </div>

  <div class="space-y-4">
    <% progress.items.each do |it| %>
      <%= link_to send("#{it.path_name}_path"), class: "block rounded-lg p-2 -m-2 transition hover:bg-gray-2/60" do %>
        <div class="mb-1.5 flex items-center justify-between gap-3">
          <div class="flex min-w-0 items-center gap-2">
            <span class="text-body"><%= ui_icon it.icon %></span>
            <span class="text-sm font-medium text-boxdark"><%= it.label %></span>
            <% if it.on_track %>
              <span class="flex items-center gap-1 rounded-full bg-success/10 px-2 py-0.5 text-xs font-medium text-success">
                <%= ui_icon :check, css: "h-3.5 w-3.5" %> OK
              </span>
            <% end %>
          </div>
          <span class="shrink-0 text-xs text-body"><%= it.detail %></span>
        </div>
        <div class="h-2 w-full overflow-hidden rounded-full bg-gray-2">
          <div class="h-full rounded-full <%= it.on_track ? 'bg-success' : 'bg-primary' %> transition-all" style="width: <%= it.percent %>%"></div>
        </div>
        <% if it.nudge %>
          <p class="mt-1 flex items-center gap-1 text-xs font-medium text-warning">
            <%= ui_icon :nudge, css: "h-3.5 w-3.5" %> <%= it.nudge %>
          </p>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
