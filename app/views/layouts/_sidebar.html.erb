<% nav = ->(active) { active ? "bg-primary/90 text-white" : "text-bodydark hover:bg-white/10 hover:text-white" } %>

<aside class="hidden w-72 flex-col bg-sidebar lg:flex">
  <div class="flex items-center gap-2 px-6 py-6">
    <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary text-lg font-bold text-white">L</span>
    <div class="leading-tight">
      <p class="text-base font-semibold text-white">Life Assistant</p>
      <p class="text-xs text-bodydark">Track &amp; improve</p>
    </div>
  </div>

  <nav class="flex-1 px-4 py-4">
    <p class="mb-3 ml-3 text-xs font-semibold uppercase tracking-wider text-bodydark">Menu</p>
    <ul class="flex flex-col gap-1.5">
      <li>
        <%= link_to root_path, class: "group flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition #{nav.call(current_page?(root_path))}" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1V10"/></svg>
          Accueil
        <% end %>
      </li>
      <li>
        <%= link_to today_path, class: "group flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition #{nav.call(current_page?(today_path))}" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Aujourd'hui
        <% end %>
      </li>
      <li>
        <%= link_to todos_path, class: "group flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition #{nav.call(current_page?(todos_path))}" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          Mes tâches
        <% end %>
      </li>
      <li>
        <%= link_to weight_entries_path, class: "group flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition #{nav.call(controller_name == 'weight_entries')}" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l3-3 3 3 5-6"/></svg>
          Poids
        <% end %>
      </li>
      <li>
        <%= link_to meals_path, class: "group flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition #{nav.call(controller_name == 'meals')}" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M4 3v18M4 8h6a2 2 0 002-2V3M20 3v18M18 3v6a2 2 0 002 2"/></svg>
          Repas
        <% end %>
      </li>
      <li>
        <%= link_to workouts_path, class: "group flex items-center gap-3 rounded-lg px-4 py-2.5 text-sm font-medium transition #{nav.call(controller_name == 'workouts')}" do %>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6.5 6.5l11 11M4 9l2-2m14 8l-2 2M9 4l11 11M4 9l5 5m1-11l11 11M15 20l5-5"/></svg>
          Sport
        <% end %>
      </li>
    </ul>
  </nav>

  <div class="px-6 py-5 text-xs text-bodydark border-t border-white/10">
    Ruby <%= RUBY_VERSION %> · Rails <%= Rails.version %>
  </div>
</aside>

<%# Mobile top nav (zero JS): simple horizontal bar shown on small screens %>
<div class="fixed bottom-0 left-0 z-50 flex w-full items-center justify-around border-t border-stroke bg-white py-2 lg:hidden">
  <%= link_to root_path, class: "flex flex-col items-center gap-0.5 text-xs #{current_page?(root_path) ? 'text-primary' : 'text-body'}" do %>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1V10"/></svg>
    Accueil
  <% end %>
  <%= link_to today_path, class: "flex flex-col items-center gap-0.5 text-xs #{current_page?(today_path) ? 'text-primary' : 'text-body'}" do %>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    Aujourd'hui
  <% end %>
  <%= link_to todos_path, class: "flex flex-col items-center gap-0.5 text-xs #{current_page?(todos_path) ? 'text-primary' : 'text-body'}" do %>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    Tâches
  <% end %>
  <%= link_to weight_entries_path, class: "flex flex-col items-center gap-0.5 text-xs #{controller_name == 'weight_entries' ? 'text-primary' : 'text-body'}" do %>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l3-3 3 3 5-6"/></svg>
    Poids
  <% end %>
  <%= link_to meals_path, class: "flex flex-col items-center gap-0.5 text-xs #{controller_name == 'meals' ? 'text-primary' : 'text-body'}" do %>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M4 3v18M4 8h6a2 2 0 002-2V3M20 3v18M18 3v6a2 2 0 002 2"/></svg>
    Repas
  <% end %>
  <%= link_to workouts_path, class: "flex flex-col items-center gap-0.5 text-xs #{controller_name == 'workouts' ? 'text-primary' : 'text-body'}" do %>
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M6.5 6.5l11 11M4 9l2-2m14 8l-2 2M9 4l11 11"/></svg>
    Sport
  <% end %>
</div>
