<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Life Assistant" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Life Assistant">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="text-body font-normal antialiased" data-controller="shortcuts">
    <%# Keyboard shortcuts cheatsheet — toggled with "?" (see shortcuts_controller). %>
    <div data-shortcuts-target="cheatsheet"
         data-action="click->shortcuts#hideCheatsheet"
         class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/40 p-4">
      <div class="w-full max-w-sm rounded-lg border border-stroke bg-white p-6 shadow-default" data-action="click->shortcuts#stop">
        <h2 class="mb-4 text-lg font-semibold text-boxdark">Raccourcis clavier</h2>
        <ul class="space-y-2 text-sm text-body">
          <% {
               "T" => "Aujourd'hui + nouvelle tâche",
               "P" => "Poids + nouvelle pesée",
               "R" => "Repas + saisie du jour",
               "S" => "Sport + nouvelle séance",
               "D" => "Tableau de bord",
               "L" => "Mes tâches",
               "?" => "Afficher/masquer cette aide"
             }.each do |key, label| %>
            <li class="flex items-center justify-between gap-4">
              <span><%= label %></span>
              <kbd class="rounded border border-stroke bg-gray-2 px-2 py-0.5 font-mono text-xs font-semibold text-boxdark"><%= key %></kbd>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="flex h-screen overflow-hidden">
      <%= render "layouts/sidebar" %>

      <div class="relative flex flex-1 flex-col overflow-y-auto overflow-x-hidden">
        <header class="sticky top-0 z-40 flex w-full border-b border-stroke bg-white">
          <div class="flex flex-grow items-center justify-between px-4 py-4 md:px-6 2xl:px-10">
            <div>
              <h1 class="text-lg font-semibold text-boxdark md:text-xl">
                <%= content_for(:page_title) || "Life Assistant" %>
              </h1>
              <p class="text-sm text-body"><%= content_for(:page_subtitle) %></p>
            </div>
            <div class="hidden items-center gap-4 sm:flex">
              <div class="text-right">
                <p class="text-sm font-medium text-boxdark"><%= l(Date.current, format: :long) %></p>
                <p class="text-xs text-body">Semaine <%= Date.current.cweek %></p>
              </div>
              <div class="rounded-lg bg-gray-2 px-3 py-1.5 text-right">
                <p class="font-mono text-lg font-semibold tabular-nums text-primary" data-controller="clock"><%= l(Time.current, format: "%H:%M:%S") %></p>
              </div>
            </div>
          </div>
        </header>

        <main>
          <div class="mx-auto max-w-screen-2xl p-4 md:p-6 2xl:p-10">
            <% if notice %>
              <div class="mb-6 rounded-lg border border-success/40 bg-success/10 px-4 py-3 text-sm text-success"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="mb-6 rounded-lg border border-danger/40 bg-danger/10 px-4 py-3 text-sm text-danger"><%= alert %></div>
            <% end %>
            <%= yield %>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
